# Copie ce fichier en .env et remplis les valeurs
# cp .env.example .env

# ===========================
# GOOGLE APIs (OBLIGATOIRE)
# Obtenir sur : console.cloud.google.com
# APIs à activer : Maps JavaScript API + Places API + Geocoding API
# ===========================
GOOGLE_MAPS_API_KEY=COLLE_TA_CLE_GOOGLE_ICI
VITE_GOOGLE_MAPS_KEY=COLLE_TA_CLE_GOOGLE_ICI

# ===========================
# APIFY - LinkedIn / Instagram / TikTok (OPTIONNEL)
# Obtenir sur : apify.com → Settings → Integrations
# ===========================
APIFY_API_TOKEN=

# ===========================
# FACEBOOK (OPTIONNEL)
# Obtenir sur : developers.facebook.com
# ===========================
FACEBOOK_ACCESS_TOKEN=

# ===========================
# PAPPERS.FR (OPTIONNEL — données financières entreprises françaises)
# Obtenir sur : pappers.fr → Mon compte → Clé API
# ===========================
PAPPERS_API_KEY=ta_clé_ici

# ===========================
# ANTHROPIC / CLAUDE (OPTIONNEL — analyse IA des avis)
# Obtenir sur : console.anthropic.com → API Keys
# ===========================
ANTHROPIC_API_KEY=sk-ant-...

# ===========================
# GOOGLE SHEETS (OPTIONNEL — export favoris)
# Obtenir sur : console.cloud.google.com → Service Accounts
# ===========================
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# ===========================
# CONFIGURATION SERVEUR
# ===========================
PORT=3001
NODE_ENV=development

# ===========================
# CONFIGURATION FRONTEND
# ===========================
VITE_API_URL=http://localhost:3001

# ===========================
# MODE DÉVELOPPEMENT
# Mettre à true pour utiliser des données fictives (pas besoin d'API)
# ===========================
VITE_MOCK=false
